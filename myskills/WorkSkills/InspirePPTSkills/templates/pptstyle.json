{
    "template_name": "AI_Business_Practical_Landing",
    "theme_version": "1.1.0",
    "updated_date": "2026-03-16",
    "category": "Enterprise Training / Tech Business",
    "color_system": {
        "brand_primary": {
            "starry_blues": {
                "name_cn": "星空蓝",
                "name_en": "Starry Blues",
                "hex": "#1B2B47",
                "usage": "主品牌色，用于章节页背景、关键标题、主按钮、品牌标识",
                "description": "智慧、思考和品质的国际公认色，作为智慧、思考和品质的象征，在各类传播中自如使用"
            },
            "creative_blue": {
                "name_cn": "创想蓝",
                "name_en": "Creative Blue",
                "hex": "#4A9FD8",
                "usage": "强调色，用于重点突出、惊喜元素、互动标识、高亮数据（使用比例控制在5-10%）",
                "description": "强调色，谨慎且有目的地使用，用于突出信息、带来惊喜和愉悦"
            },
            "tech_gray": {
                "name_cn": "科技灰",
                "name_en": "Tech Gray",
                "hex": "#F5F7FA",
                "usage": "背景辅助色、卡片背景、内容区域底色，营造柔和平静效果",
                "description": "用于营造柔和和平静的效果，作为背景色使用"
            }
        },
        "brand_secondary": {
            "white": {
                "name_cn": "白",
                "name_en": "White",
                "hex": "#FFFFFF",
                "usage": "内容页主背景、深色背景上的文字、卡片背景",
                "description": "纯净白，用于内容页主背景"
            },
            "amethyst": {
                "name_cn": "紫水晶",
                "name_en": "Amethyst",
                "hex": "#7B6B9E",
                "usage": "辅助信息、图表辅助色、创新类内容标识",
                "description": "紫色系辅助色，用于内容区分和凸显"
            },
            "myrtle_deep_green": {
                "name_cn": "冬青绿",
                "name_en": "Myrtle Deep Green",
                "hex": "#2F5B56",
                "usage": "成功状态、正向数据、环保/可持续主题",
                "description": "深绿色辅助色，用于正向信息和成功状态"
            },
            "cerulean_frost": {
                "name_cn": "蔚蓝霜色",
                "name_en": "Cerulean Frost",
                "hex": "#8FBCD4",
                "usage": "次要信息、轻量背景、图表浅色数据",
                "description": "浅蓝辅助色，用于次要信息和轻量背景"
            },
            "sakura_pink": {
                "name_cn": "樱花粉",
                "name_en": "Sakura Pink",
                "hex": "#E8B4B4",
                "usage": "温馨提示、人文关怀内容、创新实验标签",
                "description": "粉色辅助色，用于温馨提示和柔和内容"
            }
        },
        "functional": {
            "text_primary": {
                "hex": "#1B2B47",
                "usage": "正文主色，替代纯黑以创造更温暖的氛围",
                "note": "使用较深的灰色作为文本颜色，而不是黑色"
            },
            "text_secondary": {
                "hex": "#64748B",
                "usage": "次要文字、说明文字、时间标签"
            },
            "text_light": {
                "hex": "#94A3B8",
                "usage": "占位符文字、禁用状态、脚注"
            },
            "border": {
                "hex": "#E2E8F0",
                "usage": "卡片边框、分割线、表格边框"
            },
            "success": {
                "hex": "#10B981",
                "usage": "成功状态、正面结果、完成标识"
            },
            "warning": {
                "hex": "#F59E0B",
                "usage": "警告提示、注意事项、风险提示"
            },
            "danger": {
                "hex": "#EF4444",
                "usage": "错误提示、严重警告、删除操作"
            }
        },
        "gradients": {
            "section_background": {
                "type": "linear-gradient",
                "direction": "135deg",
                "stops": [
                    {
                        "color": "#1B2B47",
                        "position": "0%"
                    },
                    {
                        "color": "#4A9FD8",
                        "position": "100%"
                    }
                ],
                "usage": "章节分隔页、封面背景"
            },
            "dark_overlay": {
                "type": "linear-gradient",
                "direction": "to bottom",
                "stops": [
                    {
                        "color": "rgba(27, 43, 71, 0.8)",
                        "position": "0%"
                    },
                    {
                        "color": "rgba(27, 43, 71, 0.4)",
                        "position": "100%"
                    }
                ],
                "usage": "图片上方文字叠加层"
            }
        }
    },
    "typography": {
        "chinese_fonts": {
            "heading": "Source Han Sans CN (思源黑体 Bold)",
            "body": "Source Han Sans CN (思源黑体 Regular)",
            "fallback": "Microsoft YaHei, PingFang SC"
        },
        "english_fonts": {
            "heading": "Montserrat Bold, Arial Black",
            "body": "Inter, Helvetica Neue, Arial",
            "numeric": "DIN Alternate, Roboto Mono"
        },
        "hierarchy": {
            "cover_title": {
                "size": "48pt",
                "weight": "Bold",
                "color": "#FFFFFF",
                "line_height": 1.2,
                "letter_spacing": "-0.02em"
            },
            "section_title": {
                "size": "36pt",
                "weight": "Bold",
                "color": "#FFFFFF",
                "subtitle_size": "18pt",
                "subtitle_weight": "Regular",
                "number_size": "72pt",
                "number_opacity": 0.15,
                "number_color": "#4A9FD8"
            },
            "h1": {
                "size": "28pt",
                "weight": "Bold",
                "color": "#1B2B47",
                "margin_bottom": "24pt"
            },
            "h2": {
                "size": "22pt",
                "weight": "Bold",
                "color": "#1B2B47",
                "margin_bottom": "16pt"
            },
            "h3": {
                "size": "18pt",
                "weight": "SemiBold",
                "color": "#1B2B47",
                "margin_bottom": "12pt"
            },
            "body": {
                "size": "14pt",
                "weight": "Regular",
                "color": "#1B2B47",
                "line_height": 1.6,
                "max_width": "80%"
            },
            "caption": {
                "size": "12pt",
                "weight": "Regular",
                "color": "#64748B",
                "style": "Italic"
            },
            "label_accent": {
                "size": "11pt",
                "weight": "Bold",
                "color": "#4A9FD8",
                "transform": "uppercase",
                "letter_spacing": "0.05em"
            }
        }
    },
    "layout_grid": {
        "slide_ratio": "16:9",
        "margin": {
            "top": "48px",
            "bottom": "48px",
            "left": "60px",
            "right": "60px"
        },
        "columns": 12,
        "gutter": "24px",
        "safe_area": "Avoid placing content within 40px of slide edges",
        "alignment": "Left-aligned for text, Centered for chapter titles"
    },
    "page_types": {
        "cover": {
            "background": "gradient_starry_to_creative",
            "elements": [
                "Main Title (centered, white)",
                "Subtitle (centered, below title, white/80%)",
                "Date (bottom right, white/60%)",
                "Presenter Info (bottom left with photo placeholder)",
                "Company Logo (top right, white version)"
            ],
            "text_effects": "Subtle shadow for readability on gradient"
        },
        "agenda": {
            "layout": "Left title + Right 5-item list",
            "numbering": "01-05 with leading zeros, colored in #4A9FD8",
            "connector": "Vertical line or arrow between items in #1B2B47",
