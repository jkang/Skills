    "usage_guidelines": {
        "color_principles": [
            "以主色（星空蓝 #1B2B47）为主，辅助色用于信息区分和内容凸显",
            "创想蓝（#4A9FD8）作为强调色，使用比例控制在5-10%",
            "使用较深的灰色（#1B2B47）作为文本颜色，而不是纯黑，以创造更温暖的氛围",
            "请勿使用中灰或浅灰作为文字颜色，确保可读性"
        ],
        "do": [
            "使用渐变背景仅限于 Cover 和 Section 页面（Starry Blues → Creative Blue）",
            "保持内容页背景为 White 或 Tech Gray (#F5F7FA)",
            "使用强调色（Creative Blue）谨慎突出重点，而非大面积使用",
            "图表数据标签使用 DIN Alternate 字体增强专业感"
        ],
        "dont": [
            "不要将文字直接放置在图片上而无叠加层",
            "不要使用超过3种主色（Starry Blues, Creative Blue, Tech Gray 除外）",
            "不要在同一页面使用超过2种辅助色",
            "正文宽度不要超过80%以保证可读性"
        ]
    }
