            "result_highlight": {
                "background": "#F5F7FA",
                "border_left": "4px solid #2F5B56",
                "metrics_color": "#2F5B56"
            }
        },
        "interaction": {
            "badge": {
                "icon": "🎯",
                "text": "互动环节",
                "background": "#FFF9E6",
                "border": "1px solid #F59E0B",
                "text_color": "#92400E"
            },
            "background": "Subtle warm tint (#FFF9E6) or left border (#F59E0B, 4px)"
        }
    },
