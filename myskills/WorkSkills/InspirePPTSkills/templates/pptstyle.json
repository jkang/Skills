                "PART XX (top left, small, #4A9FD8)",
                "Main Title (center left, white)",
                "Duration & Topics (below title, white/80%)",
                "Decorative graphic (right side, 30% width, low opacity, white)"
            ]
        },
        "content_standard": {
            "header": "Title bar with bottom border (2px, #1B2B47)",
            "body": "Single column or Two-column layout",
            "max_bullets": 5,
            "bullet_color": "#4A9FD8",
            "spacing": "1.5x line height between items"
        },
        "case_study": {
            "header": "CASE STUDY label (#4A9FD9, uppercase, bold)",
